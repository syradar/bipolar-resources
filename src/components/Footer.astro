---
import { t } from "@/lib/i18n";

const { locale } = Astro.props;
const copy = t(locale);
---

<footer class="site-footer">
  <div class="inner">
    <p>{copy.footer.disclaimer}</p>
    <p class="small">{copy.footer.independence}</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 3rem 0 4rem;
  }

  .inner {
    width: min(100% - 2rem, var(--content-width));
    margin: 0 auto;
    color: var(--muted);
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }

  .small {
    font-size: 0.95rem;
  }
</style>
