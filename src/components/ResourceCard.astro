---
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";
import type { ResourceRecord } from "@/lib/resources";

type Props = {
  locale: Locale;
  resource: ResourceRecord;
};

const { locale, resource } = Astro.props;
const copy = t(locale);
const formattedDateAdded = new Intl.DateTimeFormat(locale, {
  dateStyle: "short",
}).format(new Date(resource.dateAdded));
const titleClass = resource.url ? "title-link" : "title-text";
---

<article
  class="card"
  data-resource-card
  data-audience={resource.audience}
  data-category={resource.category}
  data-format={resource.format}
>
  <div class="card-top">
    <span class="pill">{copy.categories[resource.category]}</span>
    <span class={`pill format-pill ${resource.format}`}>
      {copy.resourceFormats[resource.format]}
    </span>
  </div>
  <h3>
    {
      resource.url ? (
        <a
          class={titleClass}
          href={resource.url}
          target="_blank"
          rel="noreferrer"
        >
          {resource.title}
        </a>
      ) : (
        <span class={titleClass}>{resource.title}</span>
      )
    }
  </h3>
  <p class="card-description">{resource.description}</p>
  <dl class="card-meta">
    <div class="meta-audience">
      <dt>{copy.cards.audience}</dt>
      <dd>{copy.audiences[resource.audience]}</dd>
    </div>
    {
      resource.source && (
        <div class="meta-source">
          <dt>{copy.cards.source}</dt>
          <dd>{resource.source}</dd>
        </div>
      )
    }
    {
      resource.language && (
        <div class="meta-language">
          <dt>{copy.cards.language}</dt>
          <dd>{resource.language.toUpperCase()}</dd>
        </div>
      )
    }
    <div class="meta-date">
      <dt>{copy.cards.dateAdded}</dt>
      <dd>
        <time datetime={resource.dateAdded}>{formattedDateAdded}</time>
      </dd>
    </div>
  </dl>
</article>

<style>
  .card {
    display: grid;
    align-content: start;
    grid-row: span 4;
    grid-template-rows: subgrid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding: var(--space-3);
    border-radius: var(--radius);
    background: var(--surface-strong);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .card[hidden] {
    display: none !important;
  }

  .card-top {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    justify-content: space-between;
    align-items: baseline;
  }

  .pill {
    width: fit-content;
    max-width: 100%;
  }

  .pill {
    background: var(--bg);
    color: var(--text);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: var(--step--1);
  }

  h3,
  p,
  .card-meta {
    grid-column: 1 / -1;
  }

  .card-description {
    color: var(--muted);
    font-size: var(--step-0);
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin: 0;
  }

  .format-pill {
    --format-bg: #efe7d3;
    --format-text: #6b5635;
    background: var(--format-bg);
    color: var(--format-text);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: var(--step--1);
  }

  .format-pill.website {
    --format-bg: #dce6e1;
    --format-text: #3f625a;
  }

  .format-pill.book {
    --format-bg: #eadfcb;
    --format-text: #6b4f2a;
  }

  .format-pill.video {
    --format-bg: #e3d9d0;
    --format-text: #71483e;
  }

  .format-pill.podcast {
    --format-bg: #dbe2ea;
    --format-text: #435a70;
  }

  .format-pill.place {
    --format-bg: #dfe8d7;
    --format-text: #4e673b;
  }

  h3 {
    margin: 0;
    font-size: var(--step-1);
    text-wrap: balance;
  }

  .title-link {
    text-decoration-color: color-mix(in srgb, currentColor 45%, transparent);
    text-decoration-thickness: 0.07em;
    text-underline-offset: 0.12em;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease;
  }

  .title-link:hover {
    color: var(--accent);
    text-decoration-color: currentColor;
  }

  .title-text {
    text-decoration: none;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  dt {
    font-size: var(--step--1);
    color: var(--muted);
  }

  dd {
    font-size: var(--step--0);
    margin: 0.25rem 0 0;
    line-height: 1.15;
  }
</style>
