---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categories } from "@/content.config";
import { t } from "@/lib/i18n";

const locale = "sv" as const;
const copy = t(locale);
---

<BaseLayout locale={locale} title={copy.submitPage.title}>
  <section class="page">
    <h1>{copy.submitPage.title}</h1>
    <p>{copy.submitPage.intro}</p>

    <div class="panel">
      <h2>{copy.submitPage.formTitle}</h2>
      <p>{copy.submitPage.helper}</p>

      <form data-markdown-form class="form">
        <label>
          Titel
          <input name="title" required />
        </label>
        <label>
          Kort beskrivning
          <textarea name="description" rows="4" required></textarea>
        </label>
        <label>
          URL
          <input name="url" type="url" required />
        </label>
        <label>
          Kategori
          <select name="category" required>
            {
              categories.map((category) => (
                <option value={category}>{copy.categories[category]}</option>
              ))
            }
          </select>
        </label>
        <label>
          Målgrupp
          <select name="audience" required>
            <option value="egen-diagnos"
              >{copy.audiences["egen-diagnos"]}</option
            >
            <option value="anhörig">{copy.audiences.anhörig}</option>
            <option value="båda">{copy.audiences.båda}</option>
          </select>
        </label>
        <label>
          Språk
          <select name="language" required>
            <option value="sv">Svenska</option>
            <option value="en">Engelska</option>
          </select>
        </label>
        <label>
          Källa
          <input name="source" required />
        </label>
        <label>
          Taggar
          <input name="tags" placeholder="tagg1, tagg2, tagg3" />
        </label>
        <button type="submit">{copy.submitPage.download}</button>
      </form>
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-markdown-form]");

    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", (event) => {
        event.preventDefault();

        const formData = new FormData(form);
        const title = String(formData.get("title") ?? "").trim();
        const description = String(formData.get("description") ?? "").trim();
        const url = String(formData.get("url") ?? "").trim();
        const category = String(formData.get("category") ?? "").trim();
        const audience = String(formData.get("audience") ?? "").trim();
        const language = String(formData.get("language") ?? "").trim();
        const source = String(formData.get("source") ?? "").trim();
        const tags = String(formData.get("tags") ?? "")
          .split(",")
          .map((tag) => tag.trim())
          .filter(Boolean);
        const featured = false;
        const today = new Date().toISOString().slice(0, 10);

        const markdown = [
          "---",
          `title: "${title.replaceAll('"', '\\"')}"`,
          `description: "${description.replaceAll('"', '\\"')}"`,
          `url: "${url}"`,
          `category: "${category}"`,
          `audience: "${audience}"`,
          `language: "${language}"`,
          `source: "${source.replaceAll('"', '\\"')}"`,
          "tags:",
          ...(tags.length > 0 ? tags.map((tag) => `  - ${tag}`) : ["  - "]),
          `featured: ${featured ? "true" : "false"}`,
          `dateAdded: "${today}"`,
          "---",
          "",
        ].join("\n");

        const slug =
          title
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-+|-+$/g, "") || "resurs";

        const blob = new Blob([markdown], {
          type: "text/markdown;charset=utf-8",
        });
        const objectUrl = URL.createObjectURL(blob);
        const anchor = document.createElement("a");
        anchor.href = objectUrl;
        anchor.download = `${slug}.md`;
        anchor.click();
        URL.revokeObjectURL(objectUrl);
      });
    }
  </script>
</BaseLayout>

<style>
  .page {
    width: min(100% - (var(--gutter) * 2), var(--measure));
    margin: 0 auto;
    padding: var(--space-4) 0 calc(var(--space-4) * 1.35);
  }

  .panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: var(--space-3);
  }

  .form {
    display: grid;
    gap: var(--space-2);
  }

  label {
    display: grid;
    gap: var(--space-1);
    font-size: var(--step--1);
    font-weight: 600;
    font-family: var(--font-display);
  }

  input,
  textarea,
  select,
  button {
    width: 100%;
    min-height: 3rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background: var(--surface-strong);
    padding: 0.7rem 0.9rem;
    color: var(--text);
    font-family: monospace;
  }

  textarea {
    min-height: 9rem;
    resize: vertical;
  }

  .checkbox {
    grid-template-columns: auto 1fr;
    align-items: center;
  }

  .checkbox input {
    width: auto;
    min-height: auto;
  }

  button {
    margin-top: 2rem;
    font-size: var(--step-0);
    font-weight: 600;
    background: var(--accent);
    color: white;
    cursor: pointer;
    font-family: var(--font-display);
  }

  p {
    line-height: 1.75;
    color: var(--muted);
  }
</style>
