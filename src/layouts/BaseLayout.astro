---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";
import { Font } from "astro:assets";
import "@/styles/global.css";

type Props = {
  locale: Locale;
  title?: string;
  description?: string;
};

const { locale, title, description } = Astro.props;
const copy = t(locale);
const pageTitle = title ? `${title} | ${copy.siteTitle}` : copy.siteTitle;
const pageDescription = description ?? copy.siteDescription;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Font cssVariable="--font-national-park" preload />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>
  <body>
    <a class="sr-only" href="#main-content">Hoppa till innehåll</a>
    <Header locale={locale} currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
